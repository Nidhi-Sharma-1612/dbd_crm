# Neon Postgres — pooled connection string (used by the app at runtime via the pg driver adapter).
# In the Neon dashboard this is the connection string with "-pooler" in the hostname.
DATABASE_URL="postgresql://user:password@ep-example-pooler.region.aws.neon.tech/crm?sslmode=require"

# Neon Postgres — direct (unpooled) connection string, used only by Prisma Migrate.
DIRECT_URL="postgresql://user:password@ep-example.region.aws.neon.tech/crm?sslmode=require"

# Generate with: npx auth secret  (or `openssl rand -base64 33`)
AUTH_SECRET=""
